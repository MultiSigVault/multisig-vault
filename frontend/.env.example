# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Stellar Network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract
NEXT_PUBLIC_CONTRACT_ID=your_contract_id_here

# App Configuration
NEXT_PUBLIC_APP_NAME=MultiSig Vault
NEXT_PUBLIC_APP_DESCRIPTION=Multi-signature treasury vault for DAOs and teams

# Features
NEXT_PUBLIC_ENABLE_RECOVERY=true
NEXT_PUBLIC_ENABLE_SCHEDULING=true
NEXT_PUBLIC_ENABLE_TIMELOCKS=true

# Analytics
NEXT_PUBLIC_GA_ID=your_ga_id_here